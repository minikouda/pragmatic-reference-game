\newlabel{tab:io-vs-ta}{{6}{13}{Information available to each listener type. TA listeners receive the complete attribute list for all $N$ objects; IO listeners receive only the index-annotated image and the utterance}{table.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Experimental Setup}{13}{subsection.6.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.4}Results}{13}{subsection.6.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5}Analysis}{13}{subsection.6.5}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 1: \textit  {io-index} dominates all other IO listeners, with the gap widening at larger $N$.}{13}{section*.26}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces CPA at $c{=}0.50$ for image-only (IO) listeners across all six datasets ($n{=}300$ each). IO-IX = \textit  {io-index} (single integer output, never asks), IO-DR = \textit  {io-direct}, IO-EL = \textit  {io-elimination}, IO-CoT = \textit  {io-cot}. \textit  {io-index} CPA is invariant to $c$ since ask\%\,$=$\,0. Compare with Table~\ref {tab:fullscale} (text-assisted baselines).}}{14}{table.caption.23}\protected@file@percent }
\newlabel{tab:io-c05}{{7}{14}{CPA at $c{=}0.50$ for image-only (IO) listeners across all six datasets ($n{=}300$ each). IO-IX = \textit {io-index} (single integer output, never asks), IO-DR = \textit {io-direct}, IO-EL = \textit {io-elimination}, IO-CoT = \textit {io-cot}. \textit {io-index} CPA is invariant to $c$ since ask\%\,$=$\,0. Compare with Table~\ref {tab:fullscale} (text-assisted baselines)}{table.caption.23}{}}
\@writefile{toc}{\contentsline {paragraph}{Finding 2: TA listeners substantially overestimate listener accuracy.}{14}{section*.27}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 3: \textit  {io-direct} is the best IO strategy that uses a probability distribution.}{14}{section*.28}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces CPA at $c{=}0.25$ for IO listeners. IO-CoT CPA turns negative at $N{=}10$, \textit  {force}: ask rate exceeds 80\% but accuracy is insufficient to compensate.}}{15}{table.caption.24}\protected@file@percent }
\newlabel{tab:io-c025}{{8}{15}{CPA at $c{=}0.25$ for IO listeners. IO-CoT CPA turns negative at $N{=}10$, \textit {force}: ask rate exceeds 80\% but accuracy is insufficient to compensate}{table.caption.24}{}}
\@writefile{toc}{\contentsline {paragraph}{Finding 4: \textit  {io-elimination} becomes overconservative at scale.}{15}{section*.29}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 5: Speaker strategy matters less under IO evaluation.}{15}{section*.30}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces CPA at $c{=}0.10$ for IO listeners. Negative CPA arises when the clarification penalty exceeds the accuracy gain from asking. IO-CoT becomes systematically unprofitable at $N \geq 8$ under the lowest cost regime.}}{16}{table.caption.25}\protected@file@percent }
\newlabel{tab:io-c01}{{9}{16}{CPA at $c{=}0.10$ for IO listeners. Negative CPA arises when the clarification penalty exceeds the accuracy gain from asking. IO-CoT becomes systematically unprofitable at $N \geq 8$ under the lowest cost regime}{table.caption.25}{}}
\@writefile{toc}{\contentsline {paragraph}{Finding 6: Performance degrades gracefully with $N$.}{16}{section*.31}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 7: The residual gap is dominated by listener capacity, not speaker quality.}{16}{section*.32}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.6}Summary and Implications}{16}{subsection.6.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Mean CPA (averaged over four speakers, \textit  {none}+\textit  {force}, $c{=}0.5$) comparing TA and IO evaluation protocols. \textit  {io-index} is the best IO listener because it never triggers the EU ask penalty; \textit  {io-direct} is the best IO listener that can in principle ask. The leakage gap grows with $N$: at $N{=}10$, text matching remains $\mathcal  {O}(1)$ while visual discrimination degrades, so the TA advantage over honest IO listeners widens.}}{17}{table.caption.33}\protected@file@percent }
\newlabel{tab:io-summary}{{10}{17}{Mean CPA (averaged over four speakers, \textit {none}+\textit {force}, $c{=}0.5$) comparing TA and IO evaluation protocols. \textit {io-index} is the best IO listener because it never triggers the EU ask penalty; \textit {io-direct} is the best IO listener that can in principle ask. The leakage gap grows with $N$: at $N{=}10$, text matching remains $\mathcal {O}(1)$ while visual discrimination degrades, so the TA advantage over honest IO listeners widens}{table.caption.33}{}}
