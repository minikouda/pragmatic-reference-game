\newlabel{tab:fullscale}{{5}{9}{CPA at $c{=}0.5$ across all six scene configurations ($n{=}300$ each). DR = \textit {direct-rank(gemini-flash)}, EL = \textit {elimination(gemini-flash)}. Feature-canonical is a rule-based oracle requiring no VLM speaker calls}{table.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Analysis}{9}{subsection.5.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 1: \textit  {direct-rank} is uniformly superior to \textit  {elimination}.}{9}{section*.11}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 2: \textit  {canonical\_vllm} is the best VLM speaker across all settings.}{9}{section*.12}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 3: Scaling from $N{=}6$ to $N{=}10$ has modest impact on \textit  {direct-rank}.}{9}{section*.13}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 4: Forced overlap (\textit  {force}) has negligible impact with \textit  {direct-rank}.}{10}{section*.14}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Finding 5: The residual gap between \textit  {canonical\_vllm} and \textit  {feature-canonical} is consistent.}{10}{section*.15}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Summary.}{10}{section*.16}\protected@file@percent }
